{
  "name": "auplc-hub-link",
  "displayName": "AUPLC Back to Hub",
  "description": "Adds a status bar shortcut back to JupyterHub.",
  "version": "0.0.0",
  "publisher": "amdresearch",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AMDResearch/aup-learning-cloud"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:auplc.backToHub"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "auplc.backToHub",
        "title": "AUPLC: Back to Hub"
      }
    ]
  },
  "scripts": {
    "precompile": "node_modules/.bin/tsc -p ../../../runtime/hub/frontend/packages/runtime-status/tsconfig.esm.json && node_modules/.bin/tsc -p ../../../runtime/hub/frontend/packages/runtime-status/tsconfig.cjs.json && node_modules/.bin/tsc -p ../../../runtime/hub/frontend/packages/runtime-status/tsconfig.types.json && node ../../../runtime/hub/frontend/packages/runtime-status/scripts/write-package-types.mjs",
    "compile": "tsc -p .",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "@auplc/runtime-status": "file:../../../runtime/hub/frontend/packages/runtime-status"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "^22.15.30",
    "@vscode/vsce": "^3.7.0",
    "typescript": "^5.4.5"
  },
  "files": [
    "out",
    "README.md",
    "LICENSE",
    "package.json"
  ]
}
