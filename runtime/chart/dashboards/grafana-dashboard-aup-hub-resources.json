{
  "title": "AUP Hub Notebook Resources",
  "tags": ["aup-learning-hub", "resources"],
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "type": "row",
      "title": "Live Notebook Footprint",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Notebook CPU Total",
      "description": "Current aggregate CPU usage across active notebook pods, shown in millicores.",
      "fieldConfig": {
        "defaults": {
          "unit": "mcores",
          "decimals": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2000 },
              { "color": "red", "value": 8000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "showPercentChange": false
      },
      "targets": [
        {
          "expr": "1000 * sum(rate(container_cpu_usage_seconds_total{namespace=\"jupyterhub\", pod=~\"jupyter-.*\", cpu=\"total\"}[$__rate_interval]))",
          "legendFormat": "total notebook CPU",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 5, "w": 12, "x": 0, "y": 1 }
    },
    {
      "type": "stat",
      "title": "Notebook Memory Total",
      "description": "Current aggregate working set memory across active notebook pods.",
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "decimals": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2147483648 },
              { "color": "red", "value": 8589934592 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "showPercentChange": false
      },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=\"jupyterhub\", pod=~\"jupyter-.*\"})",
          "legendFormat": "total notebook memory",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 1 }
    },
    {
      "type": "row",
      "title": "Per-Pod Utilization",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 }
    },
    {
      "type": "timeseries",
      "title": "Notebook CPU by Pod",
      "description": "CPU usage rate for each user notebook pod, grouped by pod and displayed in millicores.",
      "fieldConfig": {
        "defaults": {
          "unit": "mcores",
          "decimals": 1,
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "barAlignment": 0,
            "lineWidth": 2,
            "fillOpacity": 18,
            "gradientMode": "opacity",
            "spanNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "mCPU",
            "scaleDistribution": { "type": "linear" },
            "hideFrom": { "tooltip": false, "viz": false, "legend": false },
            "thresholdsStyle": { "mode": "off" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 1000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        }
      },
      "targets": [
        {
          "expr": "1000 * sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"jupyterhub\", pod=~\"jupyter-.*\", cpu=\"total\"}[$__rate_interval]))",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 7 }
    },
    {
      "type": "timeseries",
      "title": "Notebook Memory by Pod",
      "description": "Working set memory for each user notebook pod.",
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "decimals": 1,
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "barAlignment": 0,
            "lineWidth": 2,
            "fillOpacity": 18,
            "gradientMode": "opacity",
            "spanNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "memory",
            "scaleDistribution": { "type": "linear" },
            "hideFrom": { "tooltip": false, "viz": false, "legend": false },
            "thresholdsStyle": { "mode": "off" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1073741824 },
              { "color": "red", "value": 4294967296 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        }
      },
      "targets": [
        {
          "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=\"jupyterhub\", pod=~\"jupyter-.*\"})",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 7 }
    },
    {
      "type": "row",
      "title": "Largest Current Consumers",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 }
    },
    {
      "type": "timeseries",
      "title": "Top CPU Pods",
      "description": "The five notebook pods with the highest current CPU usage.",
      "fieldConfig": {
        "defaults": {
          "unit": "mcores",
          "decimals": 1,
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "barAlignment": 0,
            "lineWidth": 2,
            "fillOpacity": 12,
            "gradientMode": "opacity",
            "spanNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "mCPU",
            "scaleDistribution": { "type": "linear" },
            "hideFrom": { "tooltip": false, "viz": false, "legend": false },
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 1000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        }
      },
      "targets": [
        {
          "expr": "topk(5, 1000 * sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"jupyterhub\", pod=~\"jupyter-.*\", cpu=\"total\"}[$__rate_interval])))",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 17 }
    },
    {
      "type": "timeseries",
      "title": "Top Memory Pods",
      "description": "The five notebook pods with the highest current working set memory.",
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "decimals": 1,
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "barAlignment": 0,
            "lineWidth": 2,
            "fillOpacity": 12,
            "gradientMode": "opacity",
            "spanNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "memory",
            "scaleDistribution": { "type": "linear" },
            "hideFrom": { "tooltip": false, "viz": false, "legend": false },
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1073741824 },
              { "color": "red", "value": 4294967296 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        }
      },
      "targets": [
        {
          "expr": "topk(5, sum by (pod) (container_memory_working_set_bytes{namespace=\"jupyterhub\", pod=~\"jupyter-.*\"}))",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 17 }
    }
  ]
}
