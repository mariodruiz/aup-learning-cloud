{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo",
    "rootDir": "./src",
    "outDir": "./lib",
    "composite": false,
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "allowImportingTsExtensions": false,
    "baseUrl": ".",
    "paths": {
      "@auplc/runtime-status": ["../runtime-status/dist/types/index.d.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts"]
}
