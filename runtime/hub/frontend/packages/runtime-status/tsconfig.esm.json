{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.esm.tsbuildinfo",
    "outDir": "./dist/esm",
    "composite": false,
    "noEmit": false,
    "emitDeclarationOnly": false,
    "declaration": false,
    "declarationMap": false,
    "allowImportingTsExtensions": false
  },
  "exclude": ["src/**/*.test.ts"]
}
